{
    "name": "fastaar/fastaar-php",
    "description": "PHP SDK for the Fastaar payment gateway — accept bKash & Nagad payments in Bangladesh.",
    "type": "library",
    "license": "MIT",
    "keywords": ["fastaar", "bkash", "nagad", "payments", "bangladesh"],
    "require": {
        "php": "^8.1",
        "ext-curl": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Fastaar\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Fastaar\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    }
}
